{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "button-group",
  "description": "Visually joins a row or column of buttons into one bordered unit",
  "dependencies": [],
  "registryDependencies": [
    "@boldkit/utils",
    "@boldkit/button"
  ],
  "files": [
    {
      "path": "registry/default/ui/button-group.tsx",

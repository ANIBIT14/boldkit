{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "radar-chart",
  "type": "registry:ui",
  "description": "A radar/spider chart component with neubrutalism styling for multi-dimensional data visualization",
  "dependencies": [
    "vue-echarts",
    "echarts",
    "class-variance-authority"
  ],
  "registryDependencies": [
    "@boldkit/utils",
    "@boldkit/chart-utils"
  ],
  "files": [
    {
      "path": "registry/default/ui/RadarChart.vue",
      "type": "registry:ui",
      "target": "components/ui/RadarChart.vue"
    },
    {
      "path": "registry/default/ui/ChartEmpty.vue",
      "type": "registry:ui",
      "target": "components/ui/ChartEmpty.vue"
    },
    {
      "path": "registry/default/ui/chart-utils.ts",
      "type": "registry:ui",
      "target": "components/ui/chart-utils.ts"
    },
    {
      "path": "registry/default/ui/chart-variants.ts",
      "type": "registry:ui",
      "target": "components/ui/chart-variants.ts"
    }
  ]
}
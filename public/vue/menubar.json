      "type": "registry:ui",
      "target": "components/ui/MenubarShortcut.vue"
    },
    {
      "path": "registry/default/ui/MenubarSub.vue",
      "type": "registry:ui",
      "target": "components/ui/MenubarSub.vue"
    },
    {
      "path": "registry/default/ui/MenubarSubTrigger.vue",
      "type": "registry:ui",

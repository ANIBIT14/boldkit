    {
      "path": "registry/default/ui/MenubarTrigger.vue",
      "type": "registry:ui",
      "target": "components/ui/MenubarTrigger.vue"
    },
    {
      "path": "registry/default/ui/MenubarContent.vue",
      "type": "registry:ui",
      "target": "components/ui/MenubarContent.vue"
    },
    {
      "path": "registry/default/ui/MenubarItem.vue",
      "type": "registry:ui",
      "target": "components/ui/MenubarItem.vue"
    },
    {
      "path": "registry/default/ui/MenubarCheckboxItem.vue",
      "type": "registry:ui",
      "target": "components/ui/MenubarCheckboxItem.vue"
    },

{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "tooltip",
  "type": "registry:ui",
  "description": "A popup that displays information on hover",
  "dependencies": [
    "reka-ui"
  ],
  "registryDependencies": [
    "utils"
  ],
  "files": [
    {
      "path": "registry/default/ui/Tooltip.vue",
      "type": "registry:ui",
      "target": "components/ui/Tooltip.vue"
    },
    {
      "path": "registry/default/ui/TooltipTrigger.vue",
      "type": "registry:ui",
      "target": "components/ui/TooltipTrigger.vue"
    },
    {
      "path": "registry/default/ui/TooltipContent.vue",
      "type": "registry:ui",
      "target": "components/ui/TooltipContent.vue"
    },
    {
      "path": "registry/default/ui/TooltipProvider.vue",
      "type": "registry:ui",
      "target": "components/ui/TooltipProvider.vue"
    }
  ]
}
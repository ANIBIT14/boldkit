{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "funnel-chart",
  "type": "registry:ui",
  "description": "Funnel chart for conversion flows and pipeline stages",
  "dependencies": [
    "vue-echarts",
    "echarts"
  ],
  "registryDependencies": [
    "@boldkit/utils",
    "@boldkit/chart-utils"
  ],
  "files": [
    {
      "path": "registry/default/ui/FunnelChart.vue",
      "type": "registry:ui",
      "target": "components/ui/FunnelChart.vue"
    },
    {
      "path": "registry/default/ui/ChartEmpty.vue",
      "type": "registry:ui",
      "target": "components/ui/ChartEmpty.vue"
    },
    {
      "path": "registry/default/ui/chart-types.ts",
      "type": "registry:ui",
      "target": "components/ui/chart-types.ts"
    }
  ]
}
{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "layered-card",
  "type": "registry:ui",
  "description": "A card with stacked layer effects",
  "dependencies": [
    "class-variance-authority"
  ],
  "registryDependencies": [
    "utils"
  ],
  "files": [
    {
      "path": "registry/default/ui/LayeredCard.vue",
      "type": "registry:ui",
      "target": "components/ui/LayeredCard.vue"
    },
    {
      "path": "registry/default/ui/LayeredCardHeader.vue",
      "type": "registry:ui",
      "target": "components/ui/LayeredCardHeader.vue"
    },
    {
      "path": "registry/default/ui/LayeredCardTitle.vue",
      "type": "registry:ui",
      "target": "components/ui/LayeredCardTitle.vue"
    },
    {
      "path": "registry/default/ui/LayeredCardDescription.vue",
      "type": "registry:ui",
      "target": "components/ui/LayeredCardDescription.vue"
    },
    {
      "path": "registry/default/ui/LayeredCardContent.vue",
      "type": "registry:ui",
      "target": "components/ui/LayeredCardContent.vue"
    },
    {
      "path": "registry/default/ui/LayeredCardFooter.vue",
      "type": "registry:ui",
      "target": "components/ui/LayeredCardFooter.vue"
    }
  ]
}
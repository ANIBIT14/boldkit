{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "scroll-area",
  "type": "registry:ui",
  "description": "Augments native scroll functionality",
  "dependencies": [
    "reka-ui"
  ],
  "registryDependencies": [
    "utils"
  ],
  "files": [

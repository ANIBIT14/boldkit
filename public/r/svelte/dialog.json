{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "dialog",
  "type": "registry:ui",
  "description": "A modal dialog with overlay",
  "dependencies": [
    "bits-ui",
    "lucide-svelte"
  ],
  "registryDependencies": [
    "utils"
  ],
  "files": [
    {
      "path": "registry/default/ui/dialog.svelte",
      "content": "<script lang=\"ts\">\n  import { Dialog } from 'bits-ui'\n  import type { Snippet } from 'svelte'\n\n  interface Props extends Dialog.RootProps {\n    children?: Snippet\n  }\n\n  let { children, ...restProps }: Props = $props()\n</script>\n\n<Dialog.Root {...restProps}>\n  {@render children?.()}\n</Dialog.Root>\n",
      "type": "registry:ui",
      "target": "lib/components/ui/dialog.svelte"
    },
    {
      "path": "registry/default/ui/dialog-trigger.svelte",
      "content": "<script lang=\"ts\">\n  import { Dialog } from 'bits-ui'\n  import type { Snippet } from 'svelte'\n\n  interface Props extends Dialog.TriggerProps {\n    children?: Snippet\n  }\n\n  let { children, ...restProps }: Props = $props()\n</script>\n\n<Dialog.Trigger {...restProps}>\n  {@render children?.()}\n</Dialog.Trigger>\n",

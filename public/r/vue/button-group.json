{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "button-group",
  "type": "registry:ui",
  "description": "Visually joins a row or column of buttons into one bordered unit",
  "dependencies": [],
  "registryDependencies": [
    "@boldkit/utils",
    "@boldkit/button"
  ],
  "files": [
    {
      "path": "registry/default/ui/ButtonGroup.vue",
      "content": "<script setup lang=\"ts\">\nimport { cn } from '@/lib/utils'\n\nconst props = withDefaults(\n  defineProps<{\n    class?: string\n    orientation?: 'horizontal' | 'vertical'\n  }>(),\n  {\n    orientation: 'horizontal',\n  }\n)\n</script>\n\n<template>\n  <div\n    role=\"group\"\n    :class=\"\n      cn(\n        'inline-flex shadow-[4px_4px_0px_hsl(var(--shadow-color))]',\n        '[&>*]:shadow-none [&>*]:hover:translate-x-0 [&>*]:hover:translate-y-0 [&>*]:active:translate-x-0 [&>*]:active:translate-y-0',\n        props.orientation === 'horizontal'\n          ? '[&>*:not(:first-child)]:ml-[-3px]'\n          : 'flex-col [&>*:not(:first-child)]:mt-[-3px]',\n        props.class\n      )\n    \"\n  >\n    <slot />\n  </div>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/ButtonGroup.vue"
    }
  ]
}